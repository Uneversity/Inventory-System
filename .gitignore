# Local secrets — never push this
.env

# Data files — these live on the server, not in the repo
inventory.json
users.json
activity_log.txt
inventory.csv

# Python cache
__pycache__/
*.pyc
*.pyo

# Virtual environment
venv/
.venv/

# Database files — these are created at runtime and should not be tracked
#*.db means whatever file ends with .db, which is the common extension for SQLite database files. This ensures that any database file created by the application will be ignored by Git and not included in version control.
instance/
*.db

#Just in case any JSON and similar files that maybe or may not be used for data storage but are generated during runtime or contain sensitive information, we can ignore them as well.
data/
*.json
*.csv
instance/
*.db
